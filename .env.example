VICTRON_EMAIL=you@example.com
VICTRON_PASSWORD=your-password
# Optional: if omitted, the first VRM site on the account is used.
VICTRON_SITE_ID=123456
WEATHER_LATITUDE=39.707337
WEATHER_LONGITUDE=2.791675
WEATHER_TIMEZONE=Europe/Madrid
CERBO_HOST=192.168.68.84
CERBO_PORT=502
# Must be the VRM Portal ID, not the friendly site name.
CERBO_SITE_IDENTIFIER=cerbo-local
CERBO_MOCK_ENABLED=false
# Native Windows development should leave this false. Live MQTT is intended for Linux/Raspberry Pi.
CERBO_MQTT_ENABLED=false
CERBO_MQTT_HOST=192.168.68.84
CERBO_MQTT_PORT=1883
# Optional: only needed if local MQTT auth is enabled.
CERBO_MQTT_USERNAME=
CERBO_MQTT_PASSWORD=
CONTROL_INTERVAL_SECONDS=30
TELEMETRY_STALE_AFTER_SECONDS=90
MODBUS_FALLBACK_POLL_SECONDS=30
POLICY_DEBOUNCE_MS=500
POLICY_MIN_RUN_INTERVAL_SECONDS=5
WEATHER_REFRESH_SECONDS=900
SHELLY_HOST=192.168.68.90
SHELLY_PORT=80
SHELLY_SWITCH_ID=0
SHELLY_USE_HTTPS=false
# Optional: only needed if local device auth is enabled.
SHELLY_USERNAME=admin
SHELLY_PASSWORD=your-shelly-password
SHELLY_TIMEOUT_SECONDS=5.0
